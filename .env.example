# =====================================================================
# DATABASE — Supabase PostgreSQL (required)
# =====================================================================
# Get this from Supabase: Project Settings -> Database -> Connection string
# Use the POOLER endpoint (port 6543), not the direct connection (5432).
# Prefix the URI with `postgresql+psycopg://` for SQLAlchemy 2.x + psycopg 3.
#
# Example:
# DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Connection pool tuning (optional; sensible defaults applied if unset)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_STATEMENT_TIMEOUT_MS=30000
DB_ECHO=false

# Dev shortcut: create tables on startup instead of running Alembic.
# Leave as `false` in production — use `alembic upgrade head`.
AUTO_CREATE_TABLES=false

# =====================================================================
# AI provider selection (overrides config/app.yaml)
# =====================================================================
# AI_PROVIDER=claude

# --- Provider credentials (set ONLY the one you use) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# =====================================================================
# App
# =====================================================================
LOG_LEVEL=INFO
